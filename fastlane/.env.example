# Copy this to fastlane/.env.local or export the variables in your shell/CI.

# Shared app identifiers.
PKSPOT_APP_IDENTIFIER=com.pkspot.app
PKSPOT_APPLE_APP_ID=6757597683
PKSPOT_ANDROID_PACKAGE_NAME=com.pkspot.app

# App Store Connect API key.
# Create this in App Store Connect > Users and Access > Integrations > App Store Connect API.
APP_STORE_CONNECT_API_KEY_ID=
APP_STORE_CONNECT_ISSUER_ID=
APP_STORE_CONNECT_API_KEY_PATH=

# Alternative for CI: put the .p8 contents here, usually base64-encoded.
APP_STORE_CONNECT_API_KEY_CONTENT=
APP_STORE_CONNECT_API_KEY_CONTENT_BASE64=true

# Google Play Developer API service account key.
# Use either a local JSON key file path or raw JSON key data from CI secrets.
GOOGLE_PLAY_JSON_KEY_FILE=
GOOGLE_PLAY_JSON_KEY_DATA=
