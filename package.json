{
  "name": "pkspot",
  "version": "1.1.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "serve": "ng serve",
    "serve:ssr": "node dist/pkspot/server/server.mjs",
    "serve:test": "node test-server.mjs",
    "serve:ios": "npx cap run ios",
    "dev": "ng serve --watch --configuration=dev",
    "build": "ng build && node copy-proxy-server.js",
    "build:dev": "ng build --configuration=dev && node copy-proxy-server.js",
    "build:prod": "ng build --configuration=production && node copy-proxy-server.js",
    "build:android:prod": "node scripts/build-mobile.js android && npx cap sync android",
    "build:android:dev": "node scripts/build-mobile.js androiddev && npx cap sync android",
    "icons:optimize": ".venv/bin/python3 scripts/optimize_icons.py",
    "build:ios:prod": "node scripts/build-mobile.js ios && npx cap sync ios",
    "build:ios:dev": "node scripts/build-mobile.js iosdev && npx cap sync ios",
    "build:mobile:prod": "node scripts/build-mobile.js ios && npx cap sync ios && node scripts/build-mobile.js android && npx cap sync android",
    "prepare": "git config core.hooksPath .githooks || true",
    "test": "npm run test:all",
    "test:all": "npm run test:unit && npm run test:build && npm run test:emulator && npm run test:e2e && npm run test:visual",
    "test:prepush": "npm run test:unit && npm run test:emulator",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:build": "node scripts/test-build-pipeline.mjs",
    "test:e2e": "playwright test --grep-invert @visual",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:visual": "playwright test --grep @visual",
    "test:visual:update": "playwright test --grep @visual --update-snapshots",
    "emulators:start": "node scripts/run_firebase_with_local_java.js emulators:start --only firestore,functions --project demo-pkspot",
    "test:emulator": "npm run test:emulator:rules && npm run test:emulator:spot-edits && npm run emulators:test:community",
    "test:emulator:rules": "node scripts/run_firebase_with_local_java.js emulators:exec --only auth,firestore --project demo-pkspot \"node scripts/emulator_run_firestore_rules_security.js\"",
    "emulators:test:community": "node scripts/run_firebase_with_local_java.js emulators:exec --only firestore,functions --project demo-pkspot \"node scripts/emulator_run_community_flow.js\"",
    "test:emulator:spot-edits": "node scripts/run_firebase_with_local_java.js emulators:exec --only firestore,functions --project demo-pkspot \"node scripts/emulator_run_spot_edit_flow.js\"",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "deploy:rules:firestore": "npx firebase deploy --only firestore:rules",
    "deploy:rules:storage": "npx firebase deploy --only storage",
    "deploy:test:rules": "npx firebase use test && npx firebase deploy --only firestore:rules",
    "deploy:prod:rules": "npx firebase use prod && npx firebase deploy --only firestore:rules",
    "deploy:functions": "cd ./functions && npm run build && npx firebase deploy --only functions && cd ..",
    "deploy:test:functions": "npx firebase use test && cd ./functions && npm run build && npx firebase deploy --only functions && cd ..",
    "deploy:prod:functions": "npx firebase use prod && cd ./functions && npm run build && npx firebase deploy --only functions && cd .."
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.9",
    "@angular/cdk": "^21.2.7",
    "@angular/common": "^21.2.9",
    "@angular/compiler": "^21.2.9",
    "@angular/core": "^21.2.9",
    "@angular/fire": "^20.0.1",
    "@angular/forms": "^21.2.9",
    "@angular/google-maps": "^21.2.7",
    "@angular/localize": "^21.2.9",
    "@angular/material": "^21.2.7",
    "@angular/platform-browser": "^21.2.9",
    "@angular/platform-browser-dynamic": "^21.2.9",
    "@angular/platform-server": "^21.2.9",
    "@angular/router": "^21.2.9",
    "@angular/service-worker": "^21.2.9",
    "@angular/ssr": "^21.2.7",
    "@capacitor-firebase/authentication": "^8.2.0",
    "@capacitor-firebase/firestore": "^8.2.0",
    "@capacitor-firebase/storage": "^8.2.0",
    "@capacitor/android": "^8.3.0",
    "@capacitor/angular": "^2.0.3",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.3.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@capawesome/capacitor-posthog": "^8.4.1",
    "@formkit/auto-animate": "^0.9.0",
    "@types/jszip": "^3.4.1",
    "@videogular/ngx-videogular": "^8.0.0",
    "bootstrap": "^5.3.8",
    "compression": "^1.8.1",
    "express": "^4.22.1",
    "firebase": "^12.12.0",
    "firebase-admin": "^13.8.0",
    "jszip": "^3.10.1",
    "ngx-image-cropper": "^9.1.6",
    "posthog-js": "^1.369.2",
    "rxjs": "^7.8.2",
    "supercluster": "^7.1.5",
    "swiper": "^12.1.2",
    "typesense": "^2.1.0",
    "uuid": "^10.0.0",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.4.8",
    "@analogjs/vitest-angular": "^2.4.8",
    "@angular/build": "~21.2.7",
    "@angular/cli": "~21.2.7",
    "@angular/compiler-cli": "^21.2.9",
    "@angular/language-service": "^21.2.9",
    "@apphosting/adapter-angular": "^17.2.17",
    "@capacitor/cli": "^8.3.1",
    "@playwright/test": "^1.59.1",
    "@types/core-js": "^2.5.8",
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.13",
    "@types/supercluster": "^7.1.3",
    "angular-eslint": "21.3.1",
    "baseline-browser-mapping": "^2.10.19",
    "eslint": "^9.39.3",
    "firebase-tools": "^15.15.0",
    "jsdom": "^27.4.0",
    "ng-extract-i18n-merge": "^3.3.0",
    "sass": "^1.99.0",
    "schema-dts": "^1.1.5",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vitest": "^3.2.4",
    "webpack-bundle-analyzer": "^5.2.0"
  },
  "overrides": {
    "axios": "^1.15.0",
    "basic-ftp": "^5.2.3",
    "dompurify": "^3.3.4",
    "express-rate-limit": "^8.3.2",
    "fast-xml-parser": "^5.5.7",
    "flatted": "^3.4.2",
    "handlebars": "^4.7.9",
    "follow-redirects": "^1.15.12",
    "hono": "^4.12.14",
    "@hono/node-server": "^1.19.13",
    "lodash": "^4.18.1",
    "node-forge": "^1.4.0",
    "protobufjs": "^7.5.5",
    "yaml": "^2.8.3",
    "express": {
      "path-to-regexp": "0.1.13"
    },
    "router": {
      "path-to-regexp": "^8.4.2"
    },
    "replace": {
      "minimatch": "^3.1.5"
    },
    "anymatch": {
      "picomatch": "^2.3.2"
    },
    "readdirp": {
      "picomatch": "^2.3.2"
    },
    "micromatch": {
      "picomatch": "^2.3.2"
    },
    "vite": {
      "picomatch": "^4.0.4"
    },
    "tinyglobby": {
      "picomatch": "^4.0.4"
    },
    "@parcel/watcher": {
      "picomatch": "^4.0.4"
    }
  }
}
