rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth.uid != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.is_admin == true;
    }

    function isOrganizationReviewer(organizationId) {
      return request.auth.uid != null
        && exists(/databases/$(database)/documents/organizations/$(organizationId)/members/$(request.auth.uid))
        && get(/databases/$(database)/documents/organizations/$(organizationId)/members/$(request.auth.uid)).data.role in ['owner', 'admin', 'reviewer'];
    }

    function isMutualFriend(userId) {
      return request.auth.uid != null
        && request.auth.uid != userId
        && exists(/databases/$(database)/documents/users/$(request.auth.uid)/following/$(userId))
        && exists(/databases/$(database)/documents/users/$(request.auth.uid)/followers/$(userId));
    }

    function canReadSpotEdit() {
      return !('visibility' in resource.data)
        || resource.data.visibility != 'private'
        || (request.auth.uid != null && request.auth.uid == resource.data.user.uid)
        || isAdmin()
        || (
          'review_organization_id' in resource.data
          && isOrganizationReviewer(resource.data.review_organization_id)
        );
    }

    function requiresOrganizationReview(spotId) {
      let spot = get(/databases/$(database)/documents/spots/$(spotId)).data;
      return ('management' in spot && spot.management.status == 'managed')
        || (
          'stewardship' in spot
          && 'organization_ids' in spot.stewardship
          && spot.stewardship.organization_ids.size() > 0
        )
        || ('verification' in spot && spot.verification.status == 'verified');
    }

    function eventComputedFields() {
      return [
        'description',
        'start_seconds',
        'end_seconds',
        'promo_starts_at_seconds',
        'location',
        'bounds',
        'bounds_center',
        'bounds_radius_m',
        'promo_region_center',
        'promo_region_radius_m',
        'has_organization',
        'has_venue_spot',
        'venue_spot_count',
        'rsvp_counts'
      ];
    }

    function validEventRsvp(eventId, userId) {
      return request.resource.data.keys().hasOnly([
          'user_id',
          'event_id',
          'rsvp',
          'time_created',
          'time_updated'
        ])
        && request.resource.data.user_id == userId
        && request.resource.data.event_id == eventId
        && request.resource.data.rsvp in ['going', 'interested', 'notgoing']
        && request.resource.data.time_updated is timestamp
        && (
          !('time_created' in request.resource.data)
          || request.resource.data.time_created is timestamp
        );
    }

    function validContactUser() {
      return !('user' in request.resource.data)
        || (
          request.auth.uid != null
          && request.resource.data.user is map
          && request.resource.data.user.keys().hasOnly([
            'uid',
            'email',
            'display_name'
          ])
          && request.resource.data.user.keys().hasAll(['uid'])
          && request.resource.data.user.uid == request.auth.uid
          && (!('email' in request.resource.data.user) || request.resource.data.user.email is string)
          && (!('display_name' in request.resource.data.user) || request.resource.data.user.display_name is string)
        );
    }

    function validContactAnalytics() {
      return !('analytics' in request.resource.data)
        || (
          request.resource.data.analytics is map
          && request.resource.data.analytics.keys().hasOnly([
            'posthog_distinct_id',
            'posthog_session_id',
            'posthog_session_replay_url'
          ])
          && (!('posthog_distinct_id' in request.resource.data.analytics) || (
            request.resource.data.analytics.posthog_distinct_id is string
            && request.resource.data.analytics.posthog_distinct_id.size() <= 200
          ))
          && (!('posthog_session_id' in request.resource.data.analytics) || (
            request.resource.data.analytics.posthog_session_id is string
            && request.resource.data.analytics.posthog_session_id.size() <= 200
          ))
          && (!('posthog_session_replay_url' in request.resource.data.analytics) || (
            request.resource.data.analytics.posthog_session_replay_url is string
            && request.resource.data.analytics.posthog_session_replay_url.size() <= 500
          ))
        );
    }

    function validContactMessage() {
      return request.resource.data.keys().hasAll([
          'message',
          'contact_info',
          'createdAt'
        ])
        && request.resource.data.keys().hasOnly([
          'message',
          'contact_info',
          'user',
          'auth_email',
          'topic',
          'analytics',
          'locale',
          'source_path',
          'user_agent',
          'createdAt'
        ])
        && request.resource.data.message is string
        && request.resource.data.message.size() >= 1
        && request.resource.data.message.size() <= 4000
        && request.resource.data.contact_info is string
        && request.resource.data.contact_info.size() >= 1
        && request.resource.data.contact_info.size() <= 240
        && request.resource.data.createdAt is timestamp
        && (!('auth_email' in request.resource.data) || (
          request.auth.uid != null
          && request.resource.data.auth_email is string
        ))
        && (!('topic' in request.resource.data) || request.resource.data.topic in ['general', 'spot-import', 'crew'])
        && (!('locale' in request.resource.data) || request.resource.data.locale is string)
        && (!('source_path' in request.resource.data) || (
          request.resource.data.source_path is string
          && request.resource.data.source_path.size() <= 500
        ))
        && (!('user_agent' in request.resource.data) || (
          request.resource.data.user_agent is string
          && request.resource.data.user_agent.size() <= 500
        ))
        && validContactUser()
        && validContactAnalytics();
    }

    function validUserSocials() {
      return !('socials' in request.resource.data)
        || (
          request.resource.data.socials is map
          && request.resource.data.socials.keys().hasOnly([
            'instagram_handle',
            'youtube_handle',
            'other'
          ])
          && (!('instagram_handle' in request.resource.data.socials) || (
            request.resource.data.socials.instagram_handle is string
            && request.resource.data.socials.instagram_handle.size() <= 120
          ))
          && (!('youtube_handle' in request.resource.data.socials) || (
            request.resource.data.socials.youtube_handle is string
            && request.resource.data.socials.youtube_handle.size() <= 160
          ))
        );
    }

    function userCustomSocialLinksUnchanged() {
      return request.resource.data.get('socials', {}).get('other', []) ==
        resource.data.get('socials', {}).get('other', []);
    }

    function noUserCustomSocialLinksOnCreate() {
      return !('socials' in request.resource.data)
        || !('other' in request.resource.data.socials);
    }

    function validReportUserReference(userRef) {
      return userRef is map
        && userRef.keys().hasOnly([
          'uid',
          'display_name',
          'profile_picture'
        ])
        && userRef.keys().hasAll(['uid'])
        && userRef.uid is string
        && userRef.uid.size() > 0
        && userRef.uid.size() <= 128
        && (!('display_name' in userRef) || (
          userRef.display_name is string
          && userRef.display_name.size() <= 120
        ))
        && (!('profile_picture' in userRef) || (
          userRef.profile_picture is string
          && userRef.profile_picture.size() <= 500
        ));
    }

    function validUserReport() {
      return request.auth.uid != null
        && request.resource.data.keys().hasOnly([
          'reportedUser',
          'reason',
          'comment',
          'user',
          'createdAt',
          'sourcePath'
        ])
        && request.resource.data.keys().hasAll([
          'reportedUser',
          'reason',
          'user',
          'createdAt'
        ])
        && validReportUserReference(request.resource.data.reportedUser)
        && validReportUserReference(request.resource.data.user)
        && request.resource.data.user.uid == request.auth.uid
        && request.resource.data.reportedUser.uid != request.auth.uid
        && request.resource.data.reason in [
          'harassment',
          'impersonation',
          'unsafe_profile',
          'spam_or_malicious_links',
          'other'
        ]
        && request.resource.data.createdAt is timestamp
        && (!('comment' in request.resource.data) || (
          request.resource.data.comment is string
          && request.resource.data.comment.size() <= 2000
        ))
        && (!('sourcePath' in request.resource.data) || (
          request.resource.data.sourcePath is string
          && request.resource.data.sourcePath.size() <= 500
        ));
    }

    match /spots/{spotId}
    {
      // all the spots are visible to everyone, authenticated or not
      allow read: if true;

      // TODO: In the future there should be a voting feature for changes on spots.
      // Only authenticated users can create new empty spot placeholders.
      // All actual spot data must go through the edits system.
      // The cloud function will populate the spot when processing the CREATE edit.
      // Updates are disabled - changes must go through the edits system
      allow create: if request.auth.uid != null 
        && request.resource.data.keys().size() == 0;
      allow update: if false;
      allow delete: if isAdmin();
      // allow write: if request.auth.uid != null &&
      //   (resource == null || resource.data == null ?
      //      !request.resource.data.keys().hasAny(['rating', 'num_reviews', 'rating_histogram', 'highlighted_reviews']) :
      //      !request.resource.data.diff(resource.data).affectedKeys().hasAny(['rating', 'num_reviews', 'rating_histogram', 'highlighted_reviews']))
      //      && (request.resource.data.keys().hasAny(['slug']) ? exists(/databases/$(database)/documents/spot_slugs/$(request.resource.data.slug)) : true);

      match /reviews/{userId} {
        allow read: if true;
        allow create: if request.auth.uid != null 
          && request.auth.uid == userId
          && request.auth.uid == request.resource.data.user.uid
          && !exists(/databases/$(database)/documents/spots/$(spotId)/reviews/$(userId))
          && request.resource.data.rating is int 
          && request.resource.data.rating >= 1 
          && request.resource.data.rating <= 5;
        allow update: if request.auth.uid != null
          && request.auth.uid == request.resource.data.user.uid
          && request.auth.uid == userId
          && request.resource.data.rating is int 
          && request.resource.data.rating >= 1 
          && request.resource.data.rating <= 5;
        allow delete: if isAdmin() || (request.auth.uid != null
          && request.auth.uid == resource.data.user.uid
          && request.auth.uid == userId);
      }

      // Spot Reports
      match /reports/{reportId}
      {
        // Only allow to read and create if the report is from the same user.
        // Disallow altering and viewing other users reports.
        allow read: if true;
        allow create: if request.auth.uid != null 
          && request.auth.uid == request.resource.data.user.uid;
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }

      // Spot Challenges
      match /challenges/{challengeId}
      {
        allow read: if (!('release_date' in resource.data)) ||
          (resource.data.release_date <= request.time) ||
          (resource.data.user.uid == request.auth.uid);
        allow create, update: if request.auth.uid != null 
          && request.auth.uid == request.resource.data.user.uid;
        allow delete: if isAdmin();
      }

      match /edits/{editId}
      {
        allow read: if canReadSpotEdit();
        allow create: if request.auth.uid != null 
          && request.auth.uid == request.resource.data.user.uid
          && (
            !requiresOrganizationReview(spotId)
            || request.resource.data.visibility == 'private'
          );
        allow update: if false;
        allow delete: if isAdmin();

        match /votes/{userId}
        {
          allow read: if true;
          allow create, update: if request.auth.uid != null 
            && request.auth.uid == userId
            && request.auth.uid == request.resource.data.user.uid;
          allow delete: if isAdmin();
        }
      }
    }

    match /spot_clusters/{cluster}
    {
        allow read: if true;
        allow write: if false;
    }


    match /spot_slugs/{slug} {
      allow read: if true;

      allow create: if request.auth.uid != null
        && slug.matches('^[a-z0-9-]+$')
        && !exists(/databases/$(database)/documents/spot_slugs/$(slug))
        && exists(/databases/$(database)/documents/spots/$(request.resource.data.spot_id));

      allow update: if false;
      allow delete: if isAdmin();
    }

    match /event_slugs/{slug} {
      allow read: if true;

      // Admins can freely manage slug aliases (create new, repoint,
      // delete). Regular authed users can claim a new unused slug that
      // already points to a real event — kept for future user-created
      // events but not used today.
      allow create: if isAdmin()
        || (
          request.auth.uid != null
          && slug.matches('^[a-z0-9-]+$')
          && !exists(/databases/$(database)/documents/event_slugs/$(slug))
          && exists(/databases/$(database)/documents/events/$(request.resource.data.event_id))
        );
      allow update, delete: if isAdmin();
    }

    function onlyCommunityInfoCardsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'infoCards'
      ]);
    }

    // Materialized community landing pages and slug aliases are public read-only
    // data used by SSR and crawlers. Admin clients may curate only infoCards;
    // all generated fields stay owned by backend rebuild jobs.
    match /community_pages/{communityKey} {
      allow read: if true;
      allow update: if isAdmin() && onlyCommunityInfoCardsChanged();
      allow create, delete: if false;
    }

    match /community_slugs/{slug} {
      allow read: if true;
      allow write: if false;
    }

    match /posts/{post}
    {
      // every post is publicy available to everyone.
      allow read: if true;

      // only authenticated users can create and edit posts and only create and edit it if it's their post. Also, they can't set the like_count variable.
      allow create, update: if request.auth.uid != null 
        && request.auth.uid == request.resource.data.user.uid
        && !('like_count' in request.resource.data);
      allow delete: if request.auth.uid != null 
        && request.auth.uid == resource.data.user.uid;

      // match the subcollection likes
      match /likes/{userId} {
        // Only authenticated users can view who liked a post
        allow read: if request.auth.uid != null;

        // Only you can edit your like
        allow create, update: if request.auth.uid == userId
          && request.auth.uid == request.resource.data.user.uid;
        allow delete: if request.auth.uid == userId
          && request.auth.uid == resource.data.user.uid;
      }
    }
    
    match /users/{userId} 
    {
      // all users and their profiles are currently public
      allow read: if true;
      // It is not allowed to update protected fields. These are handled by cloud functions.
      allow create: if request.auth.uid != null && request.auth.uid == userId
         && !request.resource.data.keys().hasAny(['follower_count', 'following_count', 'visited_spots_count', 'spot_edits_count', 'spot_creates_count', 'media_added_count', 'signup_number', 'is_admin', 'special_badges'])
         && validUserSocials()
         && noUserCustomSocialLinksOnCreate();
      allow update: if request.auth.uid != null && request.auth.uid == userId
         && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['follower_count', 'following_count', 'visited_spots_count', 'spot_edits_count', 'spot_creates_count', 'media_added_count', 'signup_number', 'is_admin', 'special_badges'])
         && validUserSocials()
         && userCustomSocialLinksUnchanged();
      allow delete: if request.auth.uid != null && request.auth.uid == userId;

      match /following/{otherUserId} {
        // A user can only see and update his own following
        allow read: if request.auth.uid != null && request.auth.uid == userId;
        allow write: if request.auth.uid != null 
        && request.auth.uid == userId && request.auth.uid != otherUserId; 
      }
      match /followers/{otherUserId} {
        // A user can only see his own followers
        allow read: if request.auth.uid != null && request.auth.uid == userId;
        // TODO write cloud function to handle updating followers and remove this permission to write.
        allow write: if request.auth.uid != null && 
        request.auth.uid == otherUserId && request.auth.uid != userId;
      }

      match /check_ins/{checkInId} {
        // Private to the user
        allow read, create, delete: if request.auth.uid != null && request.auth.uid == userId;
        allow update: if false;
      }

      match /private_data/{docId} {
        // Private to the user - stores bookmarks and visited_spots
        allow read, write: if request.auth.uid != null && request.auth.uid == userId;
      }
    }

    match /organizations/{organizationId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();

      match /members/{userId} {
        allow read: if request.auth.uid != null
          && (request.auth.uid == userId || isAdmin() || isOrganizationReviewer(organizationId));
        allow create, update, delete: if isAdmin();
      }

      match /verified_spots/{spotId} {
        allow read: if true;
        allow write: if false;
      }

      match /managed_spots/{spotId} {
        allow read: if true;
        allow write: if false;
      }

      match /used_spots/{spotId} {
        allow read: if true;
        allow write: if false;
      }
    }

    match /events/{eventId} {
      allow read: if true;
      // Admin-only writes for now. Future plan: open to authed users for
      // free-tier event creation, with field-level validation gating
      // sponsor / promo_region / banner_src (premium-only fields).
      allow create: if isAdmin()
        && !request.resource.data.keys().hasAny(eventComputedFields());
      allow update: if isAdmin()
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(eventComputedFields());
      allow delete: if isAdmin();

      match /rsvps/{userId} {
        allow read: if request.auth.uid != null
          && (
            request.auth.uid == userId
            || isAdmin()
            || isMutualFriend(userId)
          );
        allow create, update: if request.auth.uid != null
          && request.auth.uid == userId
          && validEventRsvp(eventId, userId);
        allow delete: if request.auth.uid != null
          && (request.auth.uid == userId || isAdmin());
      }
    }

    // Series (Swiss Parkour Tour, SPL, Parkour Earth, ...) are admin-curated
    // and publicly readable.
    match /series/{seriesId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Leaderboards are read-only; only cloud functions can write
    match /leaderboards/{leaderboardId} {
      allow read: if true;
      allow write: if false;
    }

    // Media Reports
    // Authenticated users: create reports tied to their uid
    // Unauthenticated users: create reports with their email
    match /media_reports/{reportId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /user_reports/{reportId} {
      allow create: if validUserReport();
      allow read, update, delete: if isAdmin();
    }

    // Contact Messages
    // Anyone can create a message, but clients cannot read, update, or delete
    // the private inbox. Cloud Functions send Discord notifications via Admin SDK.
    match /contact_messages/{messageId} {
      allow create: if validContactMessage();
      allow read, update, delete: if false;
    }

    match /imports/{importId} {
      allow read, create, update: if isAdmin();
      allow delete: if false;

      match /chunks/{chunkId} {
        allow read, create: if isAdmin();
        allow update, delete: if false;
      }
    }
    // Collection Group Queries
    match /{path=**}/edits/{editId} {
      allow read: if canReadSpotEdit();
    }
  }
}
