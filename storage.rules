rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.get('is_admin', false) == true;
    }

    function agePolicyAllowsPublicParticipation() {
      return isSignedIn()
        && (
          !firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
          || firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.get('age_policy', {}).get('participation_state', 'allowed') in [
            'allowed',
            'platform_signal_unavailable'
          ]
        );
    }

    function hasOwnerMetadata() {
      return request.resource != null
        && request.resource.metadata.uid == request.auth.uid;
    }

    // Temporary migration switch while released clients move to media_intake.
    // Flip this to false when direct public UGC writes should be fully blocked.
    function allowLegacyPublicMediaWrites() {
      return true;
    }

    function hasModerationMetadata() {
      return request.resource != null
        && request.resource.metadata.upload_id is string
        && request.resource.metadata.upload_id.size() > 0
        && request.resource.metadata.destination_folder in [
          'profile_pictures',
          'spot_pictures',
          'post_media',
          'challenges',
          'event_media'
        ]
        && request.resource.metadata.destination_filename is string
        && request.resource.metadata.destination_filename.matches('^[A-Za-z0-9_-]+$')
        && request.resource.metadata.target_kind in [
          'profile',
          'spot',
          'post',
          'challenge',
          'event',
          'event_media'
        ];
    }

    function isUnderSize(maxBytes) {
      return request.resource != null
        && request.resource.size < maxBytes;
    }

    function isAllowedImage() {
      return request.resource != null
        && request.resource.contentType.matches('image/(jpeg|png|webp|gif)');
    }

    function isAllowedVideo() {
      return request.resource != null
        && request.resource.contentType.matches('video/(mp4|quicktime|webm)');
    }

    function isAllowedImageOrVideo() {
      return isAllowedImage() || isAllowedVideo();
    }

    function isAllowedImageUpload(filename) {
      return request.resource != null
        && (
          (request.resource.contentType == 'image/jpeg' && filename.matches('^[A-Za-z0-9_-]+\\.(jpg|jpeg)$')) ||
          (request.resource.contentType == 'image/png' && filename.matches('^[A-Za-z0-9_-]+\\.png$')) ||
          (request.resource.contentType == 'image/webp' && filename.matches('^[A-Za-z0-9_-]+\\.webp$')) ||
          (request.resource.contentType == 'image/gif' && filename.matches('^[A-Za-z0-9_-]+\\.gif$'))
        );
    }

    function isAllowedVideoUpload(filename) {
      return request.resource != null
        && (
          (request.resource.contentType == 'video/mp4' && filename.matches('^[A-Za-z0-9_-]+\\.mp4$')) ||
          (request.resource.contentType == 'video/quicktime' && filename.matches('^[A-Za-z0-9_-]+\\.mov$')) ||
          (request.resource.contentType == 'video/webm' && filename.matches('^[A-Za-z0-9_-]+\\.webm$'))
        );
    }

    function isProfilePictureFilename(filename) {
      return isSignedIn()
        && filename == request.auth.uid;
    }

    function isImportFilename(filename) {
      return filename.matches('^import_[A-Za-z0-9_-]+\\.(kml|kmz)$');
    }

    function isAllowedImportContentType() {
      return request.resource != null
        && request.resource.contentType.matches('(application/vnd\\.google-earth\\.(kml\\+xml|kmz)|application/xml|text/xml|application/octet-stream)');
    }

    match /profile_pictures/{filename} {
      allow read: if true;
      allow create, update: if allowLegacyPublicMediaWrites()
        && isProfilePictureFilename(filename)
        && agePolicyAllowsPublicParticipation()
        && hasOwnerMetadata()
        && isAllowedImage()
        && isUnderSize(10 * 1024 * 1024);
      allow delete: if isProfilePictureFilename(filename);
    }

    match /spot_pictures/{filename} {
      allow read: if true;
      allow create: if allowLegacyPublicMediaWrites()
        && isSignedIn()
        && agePolicyAllowsPublicParticipation()
        && hasOwnerMetadata()
        && isAllowedImageUpload(filename)
        && isUnderSize(50 * 1024 * 1024);
      allow update: if false;
    }

    match /post_media/{filename} {
      allow read: if true;
      allow create: if allowLegacyPublicMediaWrites()
        && isSignedIn()
        && agePolicyAllowsPublicParticipation()
        && hasOwnerMetadata()
        && (isAllowedImageUpload(filename) || isAllowedVideoUpload(filename))
        && isUnderSize(500 * 1024 * 1024);
      allow update: if false;
    }

    match /challenges/{filename} {
      allow read: if true;
      allow create: if allowLegacyPublicMediaWrites()
        && isSignedIn()
        && agePolicyAllowsPublicParticipation()
        && hasOwnerMetadata()
        && (isAllowedImageUpload(filename) || isAllowedVideoUpload(filename))
        && isUnderSize(500 * 1024 * 1024);
      allow update: if false;
    }

    match /imports/{filename} {
      allow read: if isAdmin();
      allow create: if isAdmin()
        && hasOwnerMetadata()
        && isImportFilename(filename)
        && isAllowedImportContentType()
        && isUnderSize(50 * 1024 * 1024);
    }

    // Event banners / logos / sponsor logos. Admin-only writes to match
    // the Firestore /events rules — only admins create or edit events
    // today, so only admins should upload event media.
    match /event_media/{filename} {
      allow read: if true;
      allow create: if allowLegacyPublicMediaWrites()
        && isAdmin()
        && isAllowedImageUpload(filename)
        && isUnderSize(50 * 1024 * 1024)
        && hasOwnerMetadata();
      allow update: if false;
    }

    match /media_intake/{uid}/{uploadId}/{filename} {
      allow read: if false;
      allow create: if isSignedIn()
        && request.auth.uid == uid
        && uploadId.matches('^[A-Za-z0-9_-]+$')
        && hasOwnerMetadata()
        && hasModerationMetadata()
        && request.resource.metadata.upload_id == uploadId
        && (
          (
            request.resource.metadata.destination_folder == 'profile_pictures'
            && request.resource.metadata.destination_filename == request.auth.uid
            && isAllowedImageUpload(filename)
            && agePolicyAllowsPublicParticipation()
            && isUnderSize(10 * 1024 * 1024)
          )
          || (
            request.resource.metadata.destination_folder == 'spot_pictures'
            && isAllowedImageUpload(filename)
            && agePolicyAllowsPublicParticipation()
            && isUnderSize(50 * 1024 * 1024)
          )
          || (
            request.resource.metadata.destination_folder in ['post_media', 'challenges']
            && (isAllowedImageUpload(filename) || isAllowedVideoUpload(filename))
            && agePolicyAllowsPublicParticipation()
            && isUnderSize(500 * 1024 * 1024)
          )
          || (
            request.resource.metadata.destination_folder == 'event_media'
            && isAdmin()
            && isAllowedImageUpload(filename)
            && isUnderSize(50 * 1024 * 1024)
          )
        );
    }

    match /{allPaths=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}
