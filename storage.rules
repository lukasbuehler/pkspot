rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.get('is_admin', false) == true;
    }

    function hasOwnerMetadata() {
      return request.resource != null
        && request.resource.metadata.uid == request.auth.uid;
    }

    function isUnderSize(maxBytes) {
      return request.resource != null
        && request.resource.size < maxBytes;
    }

    function isAllowedImage() {
      return request.resource != null
        && request.resource.contentType.matches('image/(jpeg|png|webp|gif)');
    }

    function isAllowedVideo() {
      return request.resource != null
        && request.resource.contentType.matches('video/(mp4|quicktime|webm)');
    }

    function isAllowedImageOrVideo() {
      return isAllowedImage() || isAllowedVideo();
    }

    function isAllowedImageUpload(filename) {
      return request.resource != null
        && (
          (request.resource.contentType == 'image/jpeg' && filename.matches('^[A-Za-z0-9_-]+\\.(jpg|jpeg)$')) ||
          (request.resource.contentType == 'image/png' && filename.matches('^[A-Za-z0-9_-]+\\.png$')) ||
          (request.resource.contentType == 'image/webp' && filename.matches('^[A-Za-z0-9_-]+\\.webp$')) ||
          (request.resource.contentType == 'image/gif' && filename.matches('^[A-Za-z0-9_-]+\\.gif$'))
        );
    }

    function isAllowedVideoUpload(filename) {
      return request.resource != null
        && (
          (request.resource.contentType == 'video/mp4' && filename.matches('^[A-Za-z0-9_-]+\\.mp4$')) ||
          (request.resource.contentType == 'video/quicktime' && filename.matches('^[A-Za-z0-9_-]+\\.mov$')) ||
          (request.resource.contentType == 'video/webm' && filename.matches('^[A-Za-z0-9_-]+\\.webm$'))
        );
    }

    function isProfilePictureFilename(filename) {
      return isSignedIn()
        && filename == request.auth.uid;
    }

    function isImportFilename(filename) {
      return filename.matches('^import_[A-Za-z0-9_-]+\\.(kml|kmz)$');
    }

    function isAllowedImportContentType() {
      return request.resource != null
        && request.resource.contentType.matches('(application/vnd\\.google-earth\\.(kml\\+xml|kmz)|application/xml|text/xml|application/octet-stream)');
    }

    match /profile_pictures/{filename} {
      allow read: if true;
      allow create, update: if isProfilePictureFilename(filename)
        && hasOwnerMetadata()
        && isAllowedImage()
        && isUnderSize(10 * 1024 * 1024);
      allow delete: if isProfilePictureFilename(filename);
    }

    match /spot_pictures/{filename} {
      allow read: if true;
      allow create: if isSignedIn()
        && hasOwnerMetadata()
        && isAllowedImageUpload(filename)
        && isUnderSize(50 * 1024 * 1024);
    }

    match /post_media/{filename} {
      allow read: if true;
      allow create: if isSignedIn()
        && hasOwnerMetadata()
        && (isAllowedImageUpload(filename) || isAllowedVideoUpload(filename))
        && isUnderSize(500 * 1024 * 1024);
    }

    match /challenges/{filename} {
      allow read: if true;
      allow create: if isSignedIn()
        && hasOwnerMetadata()
        && (isAllowedImageUpload(filename) || isAllowedVideoUpload(filename))
        && isUnderSize(500 * 1024 * 1024);
    }

    match /imports/{filename} {
      allow read: if isAdmin();
      allow create: if isAdmin()
        && hasOwnerMetadata()
        && isImportFilename(filename)
        && isAllowedImportContentType()
        && isUnderSize(50 * 1024 * 1024);
    }

    // Event banners / logos / sponsor logos. Admin-only writes to match
    // the Firestore /events rules — only admins create or edit events
    // today, so only admins should upload event media.
    match /event_media/{filename} {
      allow read: if true;
      allow create: if isAdmin()
        && isAllowedImageUpload(filename)
        && isUnderSize(50 * 1024 * 1024)
        && hasOwnerMetadata();
    }

    match /{allPaths=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}
