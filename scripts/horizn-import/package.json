{
  "name": "horizn-import",
  "version": "2.0.0",
  "description": "TypeScript-based import system for Horizn parkour spot data",
  "main": "dist/import.js",
  "scripts": {
    "build": "tsc",
    "validate": "npm run build && node dist/scripts/horizn-import/validate.js",
    "import": "npm run build && node dist/scripts/horizn-import/interactive-import.js",
    "import:test": "npm run build && node dist/scripts/horizn-import/interactive-import.js --test",
    "import:dry": "npm run build && node dist/scripts/horizn-import/interactive-import.js --test --dry-run"
  },
  "dependencies": {
    "firebase-admin": "^13.8.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.35",
    "typescript": "5.3.3"
  },
  "overrides": {
    "fast-xml-parser": "^5.5.7",
    "node-forge": "^1.4.0"
  }
}
