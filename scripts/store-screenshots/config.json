{
  "baseUrl": "http://localhost:4300",
  "outputRoot": "fastlane/generated/screenshots/ios",
  "deviceScreenshotRoot": "fastlane/generated/device-screenshots/ios",
  "captureRoot": "output/store-screenshots/captures",
  "outputMode": "composed",
  "localStorage": {
    "acceptedVersion": "5",
    "lastLocationAndZoom": {
      "location": { "lat": 47.3769, "lng": 8.5417 },
      "zoom": 13
    },
    "mapStyle": "roadmap"
  },
  "ssr": {
    "port": 4300,
    "script": "scripts/store-screenshots/ssr-server.mjs",
    "buildCommand": ["npm", "run", "build:store-screenshots"]
  },
  "defaultLocale": "en-US",
  "locales": [
    { "id": "en-US", "appLocale": "en", "androidLocale": "en-US" },
    { "id": "de-DE", "appLocale": "de", "androidLocale": "de-DE" },
    { "id": "es-ES", "appLocale": "es", "androidLocale": "es-ES" },
    { "id": "fr-FR", "appLocale": "fr", "androidLocale": "fr-FR" },
    { "id": "it", "appLocale": "it", "androidLocale": "it-IT" },
    { "id": "nl-NL", "appLocale": "nl", "androidLocale": "nl-NL" }
  ],
  "devices": [
    {
      "id": "iphone65",
      "name": "iPhone 17",
      "outputFilePattern": "Apple iPhone 17 Screenshot {index}.png",
      "output": { "width": 1242, "height": 2688 },
      "viewport": {
        "width": 414,
        "height": 896,
        "deviceScaleFactor": 3,
        "isMobile": true,
        "hasTouch": true
      },
      "nativePlatform": "ios",
      "safeArea": { "top": 59, "right": 0, "bottom": 34, "left": 0 },
      "frame": {
        "kind": "iphone",
        "border": 18,
        "radius": 72,
        "asset": {
          "path": "scripts/store-screenshots/assets/devices/ios/iPhone 17 - Black - Portrait.png",
          "width": 1350,
          "height": 2760,
          "clipRadius": 170,
          "screenClipRadius": 118,
          "screen": { "x": 72, "y": 69, "width": 1206, "height": 2622 }
        }
      }
    },
    {
      "id": "ipad129",
      "name": "iPad Pro 12.9 Display",
      "outputFilePattern": "Apple iPad Pro 12.9 Inch Screenshot {index}.png",
      "output": { "width": 2048, "height": 2732 },
      "viewport": {
        "width": 1024,
        "height": 1366,
        "deviceScaleFactor": 2,
        "isMobile": true,
        "hasTouch": true
      },
      "nativePlatform": "ios",
      "safeArea": { "top": 24, "right": 0, "bottom": 20, "left": 0 },
      "frame": {
        "kind": "ipad",
        "border": 18,
        "radius": 44,
        "asset": {
          "path": "scripts/store-screenshots/assets/devices/ios/iPad Pro (M5) 13\" - Space Black - Portrait.png",
          "width": 2300,
          "height": 3000,
          "clipRadius": 120,
          "screenClipRadius": 72,
          "screen": { "x": 118, "y": 124, "width": 2064, "height": 2752 }
        }
      }
    },
    {
      "id": "androidPhone",
      "name": "Google Pixel 7",
      "outputRoot": "fastlane/metadata/android",
      "outputPathPattern": "{androidLocale}/images/phoneScreenshots/Google Pixel 7 Screenshot {index}.png",
      "deviceScreenshotRoot": "fastlane/generated/device-screenshots/android",
      "output": { "width": 1080, "height": 1920 },
      "viewport": {
        "width": 360,
        "height": 800,
        "deviceScaleFactor": 3,
        "isMobile": true,
        "hasTouch": true
      },
      "nativePlatform": "android",
      "safeArea": { "top": 48, "right": 0, "bottom": 24, "left": 0 },
      "frame": {
        "kind": "android-phone",
        "border": 14,
        "radius": 48,
        "asset": {
          "path": "scripts/store-screenshots/assets/devices/android/Google Pixel 7 - Black - Portrait.png",
          "width": 1118,
          "height": 2361,
          "clipRadius": 58,
          "screenClipRadius": 42,
          "screen": { "x": 36, "y": 47, "width": 1034, "height": 2253 }
        }
      }
    },
    {
      "id": "androidTablet10",
      "name": "Android Tablet 10 Inch",
      "outputRoot": "fastlane/metadata/android",
      "outputPathPattern": "{androidLocale}/images/tenInchScreenshots/Samsung Galaxy Tab S7 Screenshot {index}.png",
      "deviceScreenshotRoot": "fastlane/generated/device-screenshots/android",
      "output": { "width": 1600, "height": 2560 },
      "viewport": {
        "width": 800,
        "height": 1280,
        "deviceScaleFactor": 2,
        "isMobile": true,
        "hasTouch": true
      },
      "nativePlatform": "android",
      "safeArea": { "top": 24, "right": 0, "bottom": 24, "left": 0 },
      "frame": { "kind": "android-tablet", "border": 16, "radius": 34 }
    }
  ],
  "captures": [
    {
      "id": "spot",
      "path": "/{appLocale}/__visual/spot-bottom-sheet",
      "waitForSelector": "app-map-spot-details-panel, app-spot-details",
      "settleMs": 5000,
      "hideSelectors": [
        ".dev-mode-banner",
        "app-footer",
        "footer",
        ".terms-footer"
      ]
    },
    {
      "id": "map",
      "path": "/{appLocale}/map?filters=dry",
      "waitForSelector": "app-root",
      "settleMs": 5000,
      "hideSelectors": [".dev-mode-banner"]
    },
    {
      "id": "filters",
      "path": "/{appLocale}/__visual/map-overlay",
      "waitForSelector": "app-filter-chips-bar, app-search-field",
      "settleMs": 5000,
      "hideSelectors": [".dev-mode-banner"]
    }
  ],
  "deviceScreenshots": [
    {
      "capture": "map",
      "index": 1
    }
  ],
  "scenes": [
    {
      "id": "discover",
      "copyKey": "discover",
      "index": 1,
      "accent": "#a9b7ff",
      "layouts": {
        "iphone65": {
          "text": { "x": 88, "y": 1900, "width": 720, "align": "left" },
          "placements": [
            {
              "capture": "map",
              "x": 230,
              "y": 500,
              "width": 660,
              "rotate": -9,
              "imageScale": 1
            }
          ]
        },
        "ipad129": {
          "text": { "x": 170, "y": 220, "width": 740, "align": "left" },
          "placements": [
            {
              "capture": "map",
              "x": 1030,
              "y": 520,
              "width": 760,
              "rotate": -7,
              "imageScale": 1
            }
