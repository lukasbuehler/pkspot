{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "lib": ["ES2020"],
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "experimentalDecorators": true,
    "useDefineForClassFields": false
  },
  "include": ["./*.ts", "../src/**/*.ts"],
  "exclude": ["node_modules", "dist", "horizn-import"]
}
